# ==========================================================
# Docker build context exclusions
# Giữ build nhanh bằng cách loại bỏ file không cần thiết
# ==========================================================

# ── VCS / local env ─────────────────────────────────────────
.git
.gitignore
.env
.env.backup
.env.docker
.env.example

# ── Local runtime/cache artifacts ───────────────────────────
docker-data/
.sunlint-cache/
.phpunit.result.cache
storage/framework/sessions/*
storage/framework/views/*
storage/framework/testing/
storage/logs/*
storage/debugbar/

# ── Dependencies (installed inside image) ───────────────────
node_modules/
vendor/

# ── Test / dev-only files ───────────────────────────────────
tests/
phpunit.xml
dev.bat
DEMO_GUIDE.md
README.md

# ── Spring Boot project (unrelated, has own lifecycle) ──────
be-neu/

# ── IDE / editor ────────────────────────────────────────────
.vscode/
.idea/
.fleet/

# ── OS junk ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

